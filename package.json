{
  "name": "ink-stream-markdown",
  "version": "0.0.7",
  "description": "A streaming markdown renderer component for Ink",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.mts",
      "default": "./dist/browser.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "markdown.png",
    "syntax.png"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrWangJustToDo/ink-stream-markdown.git"
  },
  "homepage": "https://github.com/MrWangJustToDo/ink-stream-markdown#readme",
  "bugs": {
    "url": "https://github.com/MrWangJustToDo/ink-stream-markdown/issues"
  },
  "author": "MrWangJustToDo",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "example": "tsx test/run.tsx"
  },
  "keywords": [
    "ink",
    "markdown",
    "stream",
    "streaming",
    "react",
    "cli",
    "terminal",
    "syntax-highlighting",
    "shiki",
    "browser",
    "ink-web",
    "xterm"
  ],
  "license": "MIT",
  "peerDependencies": {
    "ink": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "chalk": "^5.6.2",
    "shiki": "^4.0.2",
    "stream-markdown-parser": "^1.0.5",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "terminal-link": "^5.0.0",
    "unicodeit": "^0.7.5",
    "wrap-ansi": "^10.0.0"
  }
}
